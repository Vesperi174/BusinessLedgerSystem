<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<!--
  MainView.fxml — 主界面布局
  BusinessLedgerSystem 桌游店业务台账系统

  布局结构：
  ┌──────────────────────────────────────────────────┐
  │  ToolBar (顶部工具栏)                              │
  ├──────────────────────┬───────────────────────────┤
  │  RoomGrid (左 60%)   │  OrderList (右 40%)        │
  │  包间卡片网格         │  今日订单表格 + 收入统计     │
  ├──────────────────────┴───────────────────────────┤
  │  StatusBar (底部状态栏)                             │
  └──────────────────────────────────────────────────┘
-->

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.businessledger.ui.controller.MainController"
            styleClass="main-root"
            stylesheets="@../css/theme.css,@../css/main.css,@../css/button.css,@../css/card.css,@../css/table.css,@../css/statusbar.css">

    <!-- ============================================================
         顶部：工具栏
         ============================================================ -->
    <top>
        <HBox styleClass="toolbar">
            <!-- 应用标题 -->
            <Label text="🎲" styleClass="toolbar-title-icon"/>
            <Label text="桌游店台账系统" styleClass="toolbar-title">
                <font>
                    <Font name="System" size="16.0"/>
                </font>
            </Label>

            <Region styleClass="toolbar-spacer" HBox.hgrow="ALWAYS"/>

            <!-- 主要操作按钮 -->
            <HBox styleClass="toolbar-actions-primary">
                <Button text="⚡ 直接开台"
                        styleClass="button-primary"
                        fx:id="btnWalkIn"
                        onAction="#handleWalkIn">
                    <tooltip><Tooltip text="直接开台（Ctrl+O）"/></tooltip>
                </Button>
                <Button text="📅 创建预约"
                        styleClass="button-outline"
                        fx:id="btnReservation"
                        onAction="#handleCreateReservation">
                    <tooltip><Tooltip text="创建预约（Ctrl+N）"/></tooltip>
                </Button>
            </HBox>

            <Region styleClass="toolbar-spacer" HBox.hgrow="ALWAYS"/>

            <!-- 次要操作按钮 -->
            <HBox styleClass="toolbar-actions-secondary">
                <Button text="💾 备份"
                        styleClass="button-secondary"
                        fx:id="btnBackup"
                        onAction="#handleBackup">
                    <tooltip><Tooltip text="数据备份（Ctrl+B）"/></tooltip>
                </Button>
                <Button text="📊 历史查询"
                        styleClass="button-secondary"
                        fx:id="btnHistory"
                        onAction="#handleHistory">
                    <tooltip><Tooltip text="历史查询（Ctrl+H）"/></tooltip>
                </Button>
            </HBox>
        </HBox>
    </top>

    <!-- ============================================================
         中间：包间区域 + 订单列表（水平分割）
         ============================================================ -->
    <center>
        <SplitPane styleClass="main-split-pane"
                   dividerPositions="0.6"
                   fx:id="mainSplitPane">

            <!-- ======== 左侧：包间卡片网格 ======== -->
            <ScrollPane styleClass="room-scroll-pane"
                        fitToWidth="true"
                        hbarPolicy="NEVER"
                        vbarPolicy="AS_NEEDED">
                <TilePane styleClass="room-grid"
                          fx:id="roomGrid"
                          hgap="16"
                          vgap="16"
                          prefColumns="3"
                          prefTileWidth="220"
                          prefTileHeight="160"
                          alignment="TOP_LEFT">
                    <!-- 7 张包间卡片由 MainController 通过代码动态生成 -->
                    <padding>
                        <Insets top="20" right="20" bottom="20" left="20"/>
                    </padding>
                </TilePane>
            </ScrollPane>

            <!-- ======== 右侧：订单列表 ======== -->
            <VBox styleClass="order-area">
                <!-- 订单列表标题 -->
                <HBox styleClass="order-area-header">
                    <Label text="📋 今日订单" styleClass="order-area-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                </HBox>

                <!-- 订单表格 -->
                <TableView fx:id="orderTable"
                           styleClass="table-view"
                           VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn text="订单号" fx:id="colOrderId"
                                     prefWidth="55" resizable="false"/>
                        <TableColumn text="包间" fx:id="colRoom"
                                     prefWidth="70"/>
                        <TableColumn text="状态" fx:id="colStatus"
                                     prefWidth="75"/>
                        <TableColumn text="人数" fx:id="colPeople"
                                     prefWidth="45" resizable="false"/>
                        <TableColumn text="金额" fx:id="colAmount"
                                     prefWidth="65"/>
                        <TableColumn text="操作" fx:id="colAction"
                                     prefWidth="70" resizable="false"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>

                <!-- 今日收入统计栏 -->
                <HBox styleClass="revenue-bar">
                    <VBox styleClass="revenue-item">
                        <Label text="今日收入" styleClass="revenue-label"/>
                        <Label text="¥ 0.00" styleClass="revenue-value-highlight"
                               fx:id="lblTodayRevenue"/>
                    </VBox>
                    <Region styleClass="revenue-divider"/>
                    <VBox styleClass="revenue-item">
                        <Label text="订单数" styleClass="revenue-label"/>
                        <Label text="0" styleClass="revenue-value"
                               fx:id="lblOrderCount"/>
                    </VBox>
                    <Region styleClass="revenue-divider"/>
                    <VBox styleClass="revenue-item">
                        <Label text="已完成" styleClass="revenue-label"/>
                        <Label text="0" styleClass="revenue-value"
                               fx:id="lblFinishedCount"/>
                    </VBox>
                </HBox>
            </VBox>
        </SplitPane>
    </center>

    <!-- ============================================================
         底部：状态栏
         ============================================================ -->
    <bottom>
        <HBox styleClass="status-bar">
            <!-- 数据库状态 -->
            <Region prefWidth="6" prefHeight="6"
                    styleClass="status-indicator,status-indicator-ok"/>
            <Label text="数据库" styleClass="status-bar-label"/>
            <Label text="正常" styleClass="status-bar-value" fx:id="lblDbStatus"/>

            <Region styleClass="status-bar-separator"/>

            <!-- 备份时间 -->
            <Label text="上次备份" styleClass="status-bar-label"/>
            <Label text="-" styleClass="status-bar-value" fx:id="lblLastBackup"/>

            <Region styleClass="status-bar-separator"/>

            <!-- 日志条数 -->
            <Label text="日志" styleClass="status-bar-label"/>
            <Label text="0 条" styleClass="status-bar-value" fx:id="lblLogCount"/>

            <Region styleClass="status-bar-spacer" HBox.hgrow="ALWAYS"/>

            <!-- 通知区域 -->
            <Label text="" styleClass="status-bar-notification"
                   fx:id="lblNotification"/>
        </HBox>
    </bottom>
</BorderPane>